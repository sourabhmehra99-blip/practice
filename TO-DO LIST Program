# to-Do List Program

# Step :1 form a empty list
main_list = []

# Step :2 define the main menu
def show_menu():
    print("\n---TO-DO LIST---")
    print("1. View the TO-DO LIST")
    print("2. Addition to TO-DO LIST")
    print("3. Remove to TO-DO LIST") 
    print("4. Clear TO-DO LIST")
    print("5. Exit ")

# Step :3 Main program loop 
while True:
    show_menu()
    choice = input("Enter your choice(1-5): ")

    if choice =="1":
        print("\n---TO-DO LIST---")
        if not main_list:
            print("your TO-DO LIST is empty.")
        else:
            for index,item in enumerate (main_list):
                print(f"{index + 1}.{item}")

    elif choice =="2":
        item = input("Enter work in TO-DO LIST: ")
        main_list.append(item)
        print(f"{item} has been added in TO-DO LIST.")
        
    elif choice =="3":
        item = input("Enter the work remove from TO-DO LIST")
        if item in main_list: 
             main_list.remove(item)
             print(f"{item} has been remove from TO-DO LIST.")
        else: 
            print(f"{item} is not in the TO-DO LIST")
    elif choice =="4":
        main_list.clear()
        print("The TO-DO LIST has been clearred.")
    elif choice == "5":
        print("Goodbye ! All the best ")
        break
    else:
        print("invaild choice. Please try again. Thanks you !")
