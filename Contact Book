# Contact book 
# step 1: initalize the dictionary
contact_book = {}

def show_menu():
    print("1. ADD Contact ")
    print("2. View Contact")
    print("3. Search Contact")
    print("4. Edit Contact ")
    print("5. Delete Contact")
    print("6. Exit ")

def Add_con():
    name = input("Enter contact name: ")
    if name in contact_book:
        print(f"contsct {name} has already in the contact book. ")
    else:
        try:
         phone = int(input("Enter contact number: "))
        except ValueError:
           print("Invalid Statement")
        email = input("Enter email number: ")
        contact_book[name] = {"phone":phone," email": email}
        print(f"{name } details has been added in the contact book. ")

def view_con():
   if contact_book:
      print("\n---Contact book---")
      for name, details in contact_book.item():
         print(f"Name: {name}")
         print(f"Phone: {details,['phone']}")
         print(f"Email: {details,['email']}")
   else:
        print('contact book is empty. ')

def search_con():
   name = input("Enter contact name you want to search: ")
   if name in contact_book:
      print(f"name: {name}")
      print(f"phone: {contact_book[name]['phone']}")
      print(f"Email: {contact_book[name]['email']}")
   else:
      print(f"{name} has not found in the contact book.\n---Try Again---")

def Edit_con():
   name = input("Enter contact name to edit: ")
   if name in contact_book:
      print("1. Edit phone.")
      print("2. Edit email.")
      choice = int(input("Enter your choice: "))
      if choice == 1:
        try:
         phone = int(input("Enter new contact number: "))
         contact_book[name]["phone"] = phone
        except ValueError:
           print("Invalid Statement")
      elif choice == 2:
         email = input("Enter new contact email: ")
         contact_book[name]['email'] = email
   else:
      print(f"{name} has not been found in the contact book. ")

def delete_con():
   name = input("Enter contact name to delete: ")
   if name in contact_book:
      del contact_book[name]
      print(f"{name} has been deleted in the contact book. ")
   else:
      print(f"{name} has not found in the contact book. ")

while True:
      show_menu()
      try:
         choice = int(input("Enter your choice(1-6): ") )
      except ValueError:
        print("Please enter a valid number!")
        continue
      match choice :
        case 1:
            Add_con()
        case 2:
            view_con()
        case 3:
            search_con()
        case 4: 
            Edit_con()
        case 5:
            delete_con()
        case 6:
            print("Exit")
            break
        case _:
            print("Invalied startment")
